local function FlingBall(targetName)
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then return end
    
    local player = LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local backpack = player:WaitForChild("Backpack")
    
    -- Tenta encontrar a pasta de bolas no Workspace (ajustado conforme o padrão do jogo)
    local ServerBalls = workspace:FindFirstChild("WorkspaceCom") and workspace.WorkspaceCom:FindFirstChild("001_SoccerBalls")
    if not ServerBalls then 
        warn("Pasta de bolas não encontrada no Workspace")
        return 
    end
    
    local function GetBall()
        -- Tenta pegar a bola se não tiver
        if not character:FindFirstChild("SoccerBall") and not backpack:FindFirstChild("SoccerBall") then
            local rs = game:GetService("ReplicatedStorage")
            if rs:FindFirstChild("RE") and rs.RE:FindFirstChild("1Too1l") then
                rs.RE["1Too1l"]:InvokeServer("PickingTools", "SoccerBall")
            end
        end
        
        repeat task.wait() until backpack:FindFirstChild("SoccerBall") or character:FindFirstChild("SoccerBall")
        
        local ballTool = backpack:FindFirstChild("SoccerBall") or character:FindFirstChild("SoccerBall")
        ballTool.Parent = character
        
        -- Aguarda a bola física aparecer no servidor/workspace
        local ballName = "Soccer" .. player.Name
        local timeout = 0
        while not ServerBalls:FindFirstChild(ballName) and timeout < 500 do
            timeout = timeout + 1.4
            task.wait(0.1)
        end
        
        return ServerBalls:FindFirstChild(ballName)
    end

    local Ball = ServerBalls:FindFirstChild("Soccer" .. player.Name) or GetBall()
    if not Ball then return end

    -- Configurações de física da bola para o Fling
    Ball.CanCollide = false
    Ball.Massless = true
    
    local tchar = target.Character
    local troot = tchar:FindFirstChild("HumanoidRootPart")
    local thum = tchar:FindFirstChild("Humanoid")

    if troot and thum then
        -- Remove velocidades antigas
        for _, v in pairs(Ball:GetChildren()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyAngularVelocity") then v:Destroy() end
        end
        
        -- Cria a força do Fling
        local bv = Instance.new("BodyVelocity")
        bv.Name = "FlingPower"
        bv.Velocity = Vector3.new(9e8, 9e8, 9e8)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.P = 9e9000000000000000000000 
        bv.Parent = Ball
        
        local bav = Instance.new("BodyAngularVelocity")
        bav.AngularVelocity = Vector3.new(9e8, 9e8, 9e8)
        bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bav.P = 9e900 
        bav.Parent = Ball

        -- Conexão para seguir o jogador
        flingConnection = RunService.Heartbeat:Connect(function()
            if not running or not tchar or not tchar.Parent or thum.Health <= 0 then
                if flingConnection then flingConnection:Disconnect() end
                if bv then bv:Destroy() end
                if bav then bav:Destroy() end
                return
            end
            
            -- Posiciona a bola no alvo com previsão de movimento
            local pos = troot.Position + (troot.Velocity * 0.5)
            Ball.CFrame = CFrame.new(pos)
        end)
    end
end
